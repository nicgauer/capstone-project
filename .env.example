# Copy to .env (on the droplet: /opt/capstone/.env) and fill in real values.
# .env is gitignored and must never be committed.

# Before a domain exists, use the droplet IP with an explicit http:// prefix
# (tells Caddy to serve plain HTTP and skip certificate provisioning):
#   DOMAIN=http://203.0.113.10
#   APP_ORIGINS=http://203.0.113.10
#   SECURE_COOKIES=false
# Once the domain's A record points at the droplet, switch to:
#   DOMAIN=example.com
#   APP_ORIGINS=https://example.com
#   SECURE_COOKIES=true
# then run `docker compose up -d` — Caddy handles certs and HTTPS redirect.
DOMAIN=http://localhost
APP_ORIGINS=http://localhost
SECURE_COOKIES=false

# Flask session/CSRF signing key — generate with: openssl rand -hex 32
SECRET_KEY=changeme

# Password for the compose-internal Postgres (user/db are both "app")
POSTGRES_PASSWORD=changeme
