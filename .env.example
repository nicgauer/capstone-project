# For LOCAL development only. Copy to .env and run `docker compose up --build`.
#
# On the droplet, .env is generated automatically by the deploy workflow
# from GitHub Secrets (DOMAIN, SECRET_KEY, POSTGRES_PASSWORD) — see
# docs/deploy.md. Don't create it there by hand.
#
# .env is gitignored and must never be committed.
DOMAIN=http://localhost
APP_ORIGINS=http://localhost
SECURE_COOKIES=false

# Flask session/CSRF signing key — generate with: openssl rand -hex 32
SECRET_KEY=changeme

# Password for the compose-internal Postgres (user/db are both "app")
POSTGRES_PASSWORD=changeme
